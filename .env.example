# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. NEVER expose to the browser. Used by admin server actions & API routes.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# EVV geofence radius in meters (default 150 if unset)
NEXT_PUBLIC_EVV_GEOFENCE_RADIUS_M=150

# ── Billing / 837P (payer-specific — see lib/billing/x12-837p.ts TODOs) ──
BILLING_SUBMITTER_ID=DLS0001
BILLING_RECEIVER_ID=COMEDICAID
BILLING_NPI=0000000000
BILLING_TAX_ID=00-0000000

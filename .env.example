# ═══════════════════════════════════════════════════════════════════════════
# DLS-CMS environment. Copy to .env.local and fill in. NEVER commit real keys.
# With NO Supabase vars set the app runs in DEMO MODE (synthetic data, no PHI).
# ═══════════════════════════════════════════════════════════════════════════

# ── Demo mode ────────────────────────────────────────────────────────────
# "true" forces demo mode even when Supabase is configured. Demo mode uses a
# deterministic in-memory synthetic dataset — NO PHI, no external services.
NEXT_PUBLIC_DEMO_MODE=true

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret (Supabase project settings → API). Server-only. Used to mint the
# admin impersonation token (sub = admin, impersonating = target user).
SUPABASE_JWT_SECRET=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# EVV geofence radius in meters (default 150 if unset)
NEXT_PUBLIC_EVV_GEOFENCE_RADIUS_M=150
# Field session idle timeout in minutes (lost-device protocol)
NEXT_PUBLIC_SESSION_IDLE_MINUTES=20

# ── HIPAA gate ───────────────────────────────────────────────────────────
# Live-PHI tripwire: integrations refuse to run against production data until
# this is explicitly set to "true" — only do so once BAAs are executed
# (Supabase, AWS, SendGrid, Relias, Sandata). See PRODUCTION-READINESS.md.
BAA_SIGNED_ALL_VENDORS=false

# ── Google OAuth (Supabase Auth → Providers → Google) ─────────────────────
# Configure client ID/secret in the Supabase dashboard; no app env needed
# beyond the callback: {NEXT_PUBLIC_APP_URL}/auth/callback

# ── Email: SendGrid ───────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notifications@durablelifeskills.com

# ── Document storage: AWS S3 ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOADS_BUCKET=dls-cms-field-uploads

# ── Google Drive (agency documents; adapter stub until configured) ───────
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Relias LMS ────────────────────────────────────────────────────────────
RELIAS_API_BASE_URL=
RELIAS_API_KEY=
RELIAS_SSO_BASE_URL=https://login.reliaslearning.com

# ── EVV aggregator: Sandata (Colorado) ────────────────────────────────────
SANDATA_API_BASE_URL=
SANDATA_AGENCY_ID=
SANDATA_USERNAME=
SANDATA_PASSWORD=

# ── Billing / 837P (payer-specific — see lib/billing/x12-837p.ts) ────────
BILLING_SUBMITTER_ID=DLS0001
BILLING_RECEIVER_ID=COMEDICAID
BILLING_NPI=0000000000
BILLING_TAX_ID=00-0000000
